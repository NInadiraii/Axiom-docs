# ============================================================
#  Speed-to-Lead Bot — Environment Variables
#  (covers both fb_lead_bot.py and line_lead_bot.py)
# ============================================================
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to version control.
# ============================================================


# ── Facebook Messenger (fb_lead_bot.py) ──────────────────────
# 1. Go to developers.facebook.com → your App → Messenger → Settings
# 2. "Page Access Token" — generate and copy it here
FB_PAGE_ACCESS_TOKEN=your_page_access_token_here

# 3. Choose any secret string — you'll paste it into the Meta Webhook
#    settings under "Verify Token" when subscribing your webhook URL.
FB_VERIFY_TOKEN=choose_a_secret_string_here


# ── LINE Messaging API (line_lead_bot.py) ────────────────────
# From: LINE Developers Console → your channel → Basic settings
LINE_CHANNEL_SECRET=your_channel_secret_here

# From: LINE Developers Console → Messaging API → Channel access token
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here


# ── Email Alert (SMTP) — shared by both bots ─────────────────
# Gmail (recommended):
#   SMTP_PORT=465  → SSL        (smtplib.SMTP_SSL)
#   SMTP_PORT=587  → STARTTLS   (smtplib.SMTP + .starttls())
#
# IMPORTANT for Gmail: use an App Password, NOT your account password.
# Enable 2-Step Verification, then create one at:
#   myaccount.google.com → Security → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password_here

# Where to send the alert (can be the same address or a different one)
ALERT_EMAIL_TO=owner@yourdomain.com


# ── Telegram Push Notification — shared by both bots ─────────
# 1. Open Telegram → message @BotFather → /newbot → follow prompts
#    → copy the token (format: 123456789:ABCdef...)
TELEGRAM_BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi

# 2. Message @userinfobot in Telegram to get YOUR numeric chat ID
#    (private channel IDs start with -100...)
TELEGRAM_CHAT_ID=987654321


# ── Google Sheets (optional — activate in log_to_sheets()) ───
# Uncomment when ready:
# GOOGLE_SHEETS_CREDS_JSON={"type":"service_account","project_id":"..."}
# GOOGLE_SHEET_ID=your_google_sheet_id_here
