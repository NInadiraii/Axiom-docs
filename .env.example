# ============================================================
#  Speed-to-Lead LINE Bot — Environment Variables
# ============================================================
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to version control.
# ============================================================

# ── LINE Messaging API ───────────────────────────────────────
# From: LINE Developers Console → your channel → Basic settings
LINE_CHANNEL_SECRET=your_channel_secret_here

# From: LINE Developers Console → your channel → Messaging API → Channel access token
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here


# ── Email Alert (SMTP) ───────────────────────────────────────
# Gmail (recommended):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465   → uses SSL  (smtplib.SMTP_SSL)
#   SMTP_PORT=587   → uses STARTTLS (smtplib.SMTP + .starttls())
#
# IMPORTANT for Gmail: use an App Password, NOT your account password.
# Enable 2-Step Verification, then create one at:
#   myaccount.google.com → Security → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password_here

# Where to send the alert (can be the same address or a different one)
ALERT_EMAIL_TO=owner@yourdomain.com


# ── Telegram Push Notification ───────────────────────────────
# 1. Open Telegram and message @BotFather → /newbot → follow prompts
#    → copy the token it gives you (format: 123456789:ABCdef...)
TELEGRAM_BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi

# 2. Message @userinfobot in Telegram to get YOUR numeric chat ID
#    (or use a private channel ID — starts with -100...)
TELEGRAM_CHAT_ID=987654321


# ── Google Sheets (optional — activate in log_to_sheets()) ───
# Uncomment when ready:
# GOOGLE_SHEETS_CREDS_JSON={"type":"service_account","project_id":"..."}
# GOOGLE_SHEET_ID=your_google_sheet_id_here
